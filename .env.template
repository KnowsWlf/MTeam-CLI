# ── M-Team 多账户（数字后缀，从 _1 开始连续编号）───────────────────
# 凭证与 API key、Telegram/飞书 按账户独立。SMTP 服务器是全局的，收件人按账户。
#
# 凭证（相互独立，可只配其一）：
#   保活（login/run/schedule）需要 USERNAME + PASSWORD + TOTP_SECRET
#   数据查询（profile/search/...）需要 API_KEY（M-Team 控制台「实验室」生成）

# ===== 账户 1 =====
MTEAM_USERNAME_1=user1
MTEAM_PASSWORD_1=pass1
MTEAM_TOTP_SECRET_1=totp1
MTEAM_API_KEY_1=apikey1

# 账户 1 的通知（每个渠道各自 opt-in；都留空 = 该账户不发通知）
# Telegram（token + chat_id 都填才启用）
NOTIFY_TELEGRAM_TOKEN_1=
NOTIFY_TELEGRAM_CHAT_ID_1=
# 飞书（webhook token）
NOTIFY_FEISHU_TOKEN_1=
# SMTP 收件人（SMTP 服务器配置见下方全局区）
NOTIFY_SMTP_TO_1=

# ===== 账户 2（按需取消注释）=====
# MTEAM_USERNAME_2=user2
# MTEAM_PASSWORD_2=pass2
# MTEAM_TOTP_SECRET_2=totp2
# MTEAM_API_KEY_2=apikey2
# NOTIFY_TELEGRAM_TOKEN_2=
# NOTIFY_TELEGRAM_CHAT_ID_2=
# NOTIFY_FEISHU_TOKEN_2=
# NOTIFY_SMTP_TO_2=

# ── SMTP 服务器（全局，所有账户共享；收件人按账户 NOTIFY_SMTP_TO_<n>）───
# 465=SSL，587=STARTTLS。密码用授权码而非登录密码。
NOTIFY_SMTP_HOST=
NOTIFY_SMTP_PORT=465
NOTIFY_SMTP_USER=
NOTIFY_SMTP_PASSWORD=
NOTIFY_SMTP_FROM=
NOTIFY_SMTP_USE_TLS=true

# ── 站点 / 浏览器（一般无需改）────────────────────────────────
# MTEAM_BASE_URL=https://zp.m-team.io
# 数据 API 默认走 api.m-team.cc；如需切回 .io 取消注释：
# MTEAM_API_BASE_URL=https://api.m-team.io/api
# MTEAM_HEADLESS=true
# MTEAM_TIMEOUT_MS=60000

# ── 定时调度（全局）───────────────────────────────────────────
# MTEAM_SCHEDULE_WINDOW=09:00-11:00
# MTEAM_SCHEDULE_PRE_DELAY_RANGE=10-300
# MTEAM_SCHEDULE_HEARTBEAT_HOURS=1
